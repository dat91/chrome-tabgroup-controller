{
  "mcpServers": {
    "chrome-tabs": {
      "command": "node",
      "args": ["native-host/mcp-server.js"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session_start_team_docs.py",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/check_mcp_bridge.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
